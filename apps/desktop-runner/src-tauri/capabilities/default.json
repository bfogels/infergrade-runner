{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window access for the InferGrade Runner sidecar prototype.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/infergrade-sidecar",
          "sidecar": true,
          "args": [
            "start",
            "--api-url",
            {
              "validator": "^(?:https://\\S+|http://(?:localhost|127(?:\\.(?:25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)){3}|\\[::1\\])(?::\\d+)?(?:/\\S*)?)$"
            }
          ]
        }
      ]
    },
    {
      "identifier": "shell:allow-kill",
      "allow": [
        {
          "name": "binaries/infergrade-sidecar",
          "sidecar": true
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/infergrade-sidecar",
          "sidecar": true,
          "args": [
            "pair",
            "--api-url",
            {
              "validator": "^(?:https://\\S+|http://(?:localhost|127(?:\\.(?:25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)){3}|\\[::1\\])(?::\\d+)?(?:/\\S*)?)$"
            },
            "--pair-code",
            {
              "validator": "igrp_\\S+"
            }
          ]
        },
        {
          "name": "binaries/infergrade-sidecar",
          "sidecar": true,
          "args": [
            "pair",
            "--api-url",
            {
              "validator": "^(?:https://\\S+|http://(?:localhost|127(?:\\.(?:25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)){3}|\\[::1\\])(?::\\d+)?(?:/\\S*)?)$"
            },
            "--pair-code",
            {
              "validator": "igrp_\\S+"
            },
            "--label",
            {
              "validator": ".{1,120}"
            }
          ]
        },
        {
          "name": "binaries/infergrade-sidecar",
          "sidecar": true,
          "args": ["install-runtime", "--runtime", "llama.cpp"]
        },
        {
          "name": "binaries/infergrade-sidecar",
          "sidecar": true,
          "args": [
            "install-runtime",
            "--runtime",
            "llama.cpp",
            "--runtime-id",
            {
              "validator": "[A-Za-z0-9._-]{1,120}"
            }
          ]
        },
        {
          "name": "binaries/infergrade-sidecar",
          "sidecar": true,
          "args": ["install-runtime", "--runtime", "llama.cpp", "--select-existing"]
        },
        {
          "name": "binaries/infergrade-sidecar",
          "sidecar": true,
          "args": [
            "install-runtime",
            "--runtime",
            "llama.cpp",
            "--runtime-id",
            {
              "validator": "[A-Za-z0-9._-]{1,120}"
            },
            "--select-existing"
          ]
        }
      ]
    }
  ]
}
