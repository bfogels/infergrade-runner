{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InferGrade Runner",
  "version": "0.1.22",
  "identifier": "com.infergrade.runner",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "InferGrade Runner",
        "width": 1080,
        "height": 760,
        "minWidth": 360,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/infergrade-sidecar"],
    "category": "DeveloperTool",
    "shortDescription": "Local companion app for InferGrade Runner jobs",
    "longDescription": "Pairs with InferGrade Hub, keeps the local Runner listening, and surfaces Runner process logs without terminal access."
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhDQ0E5RjlBQUY1NjUyQjEKUldTeFVsYXZtcC9LalAxSkNuY2NGWUl2VnNZMk1lMmtoNXVuWTVMaDBtREF4TFBVc29XNm9yWFoK",
      "endpoints": [
        "https://github.com/bfogels/infergrade-runner/releases/download/desktop-runner-latest/infergrade-runner-desktop-latest.json"
      ]
    }
  }
}
