#!/usr/bin/env sh
set -eu

if command -v infergrade >/dev/null 2>&1; then
  exec infergrade "$@"
fi

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="${INFERGRADE_RUNNER_REPO:-$(CDPATH= cd -- "$SCRIPT_DIR/../../../.." && pwd)}"

export PYTHONPATH="$REPO_ROOT/python/runner-core/src${PYTHONPATH:+:$PYTHONPATH}"
exec python3 -m infergrade "$@"
