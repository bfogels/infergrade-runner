{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infergrade.dev/schemas/model_ontology.schema.json",
  "title": "InferGrade Quantized Model Ontology",
  "description": "InferGrade separates enduring model lineage from concrete artifacts, runtime bindings, and benchmark subjects so comparisons remain reproducible and semantically correct.",
  "type": "object",
  "required": [
    "ontology_version",
    "model_family",
    "checkpoint",
    "quantization",
    "artifact",
    "runtime_binding",
    "benchmark_subject"
  ],
  "properties": {
    "ontology_version": { "type": "string" },
    "model_family": {
      "type": "object",
      "required": ["family_id", "family_name", "primary_modality"],
      "properties": {
        "family_id": { "type": "string" },
        "family_name": { "type": "string" },
        "publisher": { "type": ["string", "null"] },
        "parameter_scale": { "type": ["string", "null"] },
        "primary_modality": { "type": "string", "enum": ["text", "multimodal", "unknown"] }
      },
      "additionalProperties": false
    },
    "checkpoint": {
      "type": "object",
      "required": ["checkpoint_id", "checkpoint_name", "upstream_model_ref", "training_stage"],
      "properties": {
        "checkpoint_id": { "type": "string" },
        "checkpoint_name": { "type": "string" },
        "upstream_model_ref": { "type": "string" },
        "upstream_revision": { "type": ["string", "null"] },
        "training_stage": {
          "type": "string",
          "enum": ["base", "instruction_tuned", "reasoning_tuned", "domain_tuned", "unknown"]
        }
      },
      "additionalProperties": false
    },
    "quantization": {
      "type": "object",
      "required": ["quantization_status"],
      "properties": {
        "quantization_status": { "type": "string", "enum": ["quantized", "full_precision", "unknown"] },
        "quantization_format": { "type": ["string", "null"] },
        "quantization_label": { "type": ["string", "null"] },
        "quantization_family": { "type": ["string", "null"] },
        "quantization_scheme": { "type": ["string", "null"] },
        "weight_precision_bits": { "type": ["number", "null"], "minimum": 0 }
      },
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "required": ["artifact_id", "artifact_kind", "artifact_uri", "artifact_resolved_by"],
      "properties": {
        "artifact_id": { "type": "string" },
        "artifact_kind": { "type": "string", "enum": ["quantized_weights", "model_reference", "composite_bundle"] },
        "artifact_uri": { "type": "string" },
        "artifact_filename": { "type": ["string", "null"] },
        "artifact_sha256": { "type": ["string", "null"] },
        "artifact_resolved_by": { "type": "string", "enum": ["operator", "runner_default", "server_policy"] }
      },
      "additionalProperties": false
    },
    "runtime_binding": {
      "type": "object",
      "required": ["runtime_binding_id", "backend_engine", "backend_version", "execution_mode"],
      "properties": {
        "runtime_binding_id": { "type": "string" },
        "backend_engine": { "type": "string" },
        "backend_version": { "type": "string" },
        "backend_wrapper": { "type": ["string", "null"] },
        "execution_mode": { "type": "string", "enum": ["local_container", "cloud_container", "manual_external"] },
        "backend_flags_hash": { "type": "string" },
        "generation_preset_id": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "benchmark_subject": {
      "type": "object",
      "required": [
        "subject_id",
        "subject_kind",
        "family_id",
        "checkpoint_id",
        "artifact_id",
        "runtime_binding_id",
        "comparison_scope"
      ],
      "properties": {
        "subject_id": { "type": "string" },
        "subject_kind": { "type": "string", "enum": ["artifact_runtime_binding"] },
        "family_id": { "type": "string" },
        "checkpoint_id": { "type": "string" },
        "artifact_id": { "type": "string" },
        "runtime_binding_id": { "type": "string" },
        "comparison_scope": { "type": "string", "enum": ["deployable_quantized_model"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
