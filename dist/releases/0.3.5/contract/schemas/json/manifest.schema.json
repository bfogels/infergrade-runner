{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infergrade.dev/schemas/manifest.schema.json",
  "title": "InferGrade Bundle Manifest",
  "type": "object",
  "required": ["bundle_spec_version", "result_spec_version", "bundle_id", "created_at", "runner", "status", "files"],
  "properties": {
    "bundle_spec_version": { "type": "string" },
    "result_spec_version": { "type": "string" },
    "bundle_id": { "type": "string" },
    "created_at": { "type": "string" },
    "runner": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" }
      },
      "additionalProperties": true
    },
    "status": {
      "type": "object",
      "required": ["execution_status", "deployment_status", "capability_status", "validation_status"],
      "properties": {
        "execution_status": { "type": "string" },
        "deployment_status": { "type": "string" },
        "capability_status": { "type": "string" },
        "validation_status": { "type": "string" }
      },
      "additionalProperties": true
    },
    "files": {
      "type": "object",
      "required": ["results", "environment", "ontology"],
      "properties": {
        "results": {
          "type": "array",
          "items": { "type": "string" }
        },
        "validation": { "type": "string" },
        "environment": { "type": "string" },
        "ontology": { "type": "string" },
        "deployment_metrics": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
