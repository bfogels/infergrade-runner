{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infergrade.dev/schemas/run_config.schema.json",
  "title": "InferGrade Run Config",
  "type": "object",
  "required": ["run_config_spec_version", "run_config_id", "name", "created_at", "request"],
  "properties": {
    "run_config_spec_version": { "type": "string" },
    "run_config_id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": ["string", "null"] },
    "created_at": { "type": "string" },
    "created_by": { "type": ["string", "null"] },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "request": {
      "$ref": "run_request.schema.json"
    }
  },
  "additionalProperties": false
}
