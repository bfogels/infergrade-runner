{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infergrade.dev/schemas/result_record.schema.json",
  "title": "InferGrade Result Record",
  "type": "object",
  "required": [
    "spec_version",
    "bundle_id",
    "result_id",
    "ontology",
    "configuration",
    "hardware",
    "verification",
    "execution",
    "cost",
    "provenance"
  ],
  "properties": {
    "spec_version": { "type": "string" },
    "bundle_id": { "type": "string" },
    "result_id": { "type": "string" },
    "ontology": {
      "$ref": "model_ontology.schema.json"
    },
    "configuration": {
      "type": "object",
      "required": ["configuration_id", "model_base", "model_source", "backend_engine", "backend_version"],
      "properties": {
        "configuration_id": { "type": "string" },
        "model_base": { "type": "string" },
        "model_variant": { "type": ["string", "null"] },
        "model_instance_name": { "type": ["string", "null"] },
        "model_source": { "type": "string" },
        "model_source_repo": { "type": ["string", "null"] },
        "model_revision": { "type": ["string", "null"] },
        "quant_label": { "type": ["string", "null"] },
        "quant_format": { "type": ["string", "null"] },
        "quant_artifact_sha256": { "type": ["string", "null"] },
        "backend_engine": { "type": "string" },
        "backend_wrapper": { "type": ["string", "null"] },
        "backend_version": { "type": "string" },
        "backend_execution": { "type": ["string", "null"] },
        "backend_flags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tokenizer_id": { "type": ["string", "null"] },
        "chat_template_id": { "type": ["string", "null"] },
        "generation_preset_id": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "hardware": {
      "type": "object",
      "required": ["hardware_id", "environment_class", "accelerator_type", "accelerator_count", "os"],
      "properties": {
        "hardware_id": { "type": "string" },
        "environment_class": { "type": "string" },
        "accelerator_type": { "type": "string" },
        "accelerator_vendor": { "type": ["string", "null"] },
        "accelerator_model": { "type": ["string", "null"] },
        "accelerator_vram_gb": { "type": ["number", "null"] },
        "accelerator_count": { "type": "integer" },
        "cpu_model": { "type": ["string", "null"] },
        "memory_gb": { "type": ["number", "null"] },
        "os": { "type": "string" }
      },
      "additionalProperties": true
    },
    "verification": {
      "type": "object",
      "required": ["verification_level", "artifact_pinned", "backend_version_pinned", "hardware_captured", "missing_requirements"],
      "properties": {
        "verification_level": { "type": "string", "enum": ["verified", "community", "experimental"] },
        "artifact_pinned": { "type": "boolean" },
        "backend_version_pinned": { "type": "boolean" },
        "hardware_captured": { "type": "boolean" },
        "local_comparison_grade_candidate": { "type": ["string", "null"] },
        "missing_requirements": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "execution": {
      "type": "object",
      "required": ["execution_profile_id", "execution_mode", "started_at", "completed_at", "benchmark_job_runtime_seconds", "execution_cost_source"],
      "properties": {
        "execution_profile_id": { "type": "string" },
        "execution_mode": { "type": "string", "enum": ["local_container", "local_native", "cloud_container", "manual_external"] },
        "runtime_selector": { "$ref": "runtime_selector.schema.json" },
        "benchmark_job_runtime_seconds": { "type": "integer", "minimum": 0 },
        "execution_cost_source": { "type": "string" }
      },
      "additionalProperties": true
    },
    "capability": {
      "type": "object",
      "properties": {
        "use_case": { "type": "string", "enum": ["agentic_coding", "general_assistant", "reasoning"] },
        "capability_suite_id": { "type": ["string", "null"] },
        "benchmark_tier": { "type": ["string", "null"] },
        "capability_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "capability_score_method": { "type": ["string", "null"] },
        "capability_score_details": {
          "type": "object",
          "properties": {
            "surface_id": { "type": ["string", "null"] },
            "score_label": { "type": ["string", "null"] },
            "score_version": { "type": ["string", "null"] },
            "score_method": { "type": ["string", "null"] },
            "protocol_version": { "type": ["string", "null"], "pattern": "^[0-9]+\\.[0-9]+$" },
            "protocol_label": { "type": ["string", "null"] },
            "scale_interpretation": { "type": ["string", "null"] },
            "ceiling_display_policy": { "type": ["string", "null"] },
            "score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
            "observed_weighted_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
            "raw_attainment": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
            "calibration": { "type": ["object", "null"], "additionalProperties": true },
            "score_ready": { "type": "boolean" },
            "reason": { "type": "string" },
            "failed_gates": { "type": "array", "items": { "type": "string", "minLength": 1 } },
            "coverage": { "type": ["object", "null"], "additionalProperties": true },
            "components": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
            "diagnostic_components": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
            "ceiling": {
              "type": "object",
              "properties": {
                "reached": { "type": "boolean" },
                "status": { "enum": ["suite_ceiling_reached", "below_suite_ceiling"] },
                "label": { "type": "string", "minLength": 1 },
                "interpretation": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": true
            },
            "eligibility": {
              "type": "object",
              "required": ["minimum_scored_components", "observed_scored_components", "minimum_score_dimensions", "observed_score_dimensions", "coverage_ready", "diversity_ready", "maximum_component_weight_fraction", "influence_ready"],
              "properties": {
                "minimum_scored_components": { "type": "integer", "minimum": 2 },
                "observed_scored_components": { "type": "integer", "minimum": 0 },
                "minimum_score_dimensions": { "type": "integer", "minimum": 2 },
                "observed_score_dimensions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
                "coverage_ready": { "type": "boolean" },
                "diversity_ready": { "type": "boolean" },
                "maximum_component_weight_fraction": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
                "influence_ready": { "type": "boolean" },
                "minimum_benchmark_tier": { "type": ["string", "null"], "enum": ["standard", "gold", null] },
                "observed_benchmark_tier": { "type": ["string", "null"], "enum": ["canary", "standard", "gold", null] },
                "benchmark_depth_ready": { "type": "boolean" }
              },
              "additionalProperties": false
            },
            "robustness": {
              "type": "object",
              "required": ["method", "leave_one_component_out", "dominant_component", "dominant_benchmark_ids", "maximum_observed_weight_fraction", "claim_boundary"],
              "properties": {
                "method": { "const": "leave_one_component_out_v1" },
                "leave_one_component_out": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
                "max_absolute_delta": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
                "dominant_component_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
                "dominant_component": { "type": "boolean" },
                "dominant_benchmark_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
                "maximum_observed_weight_fraction": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
                "claim_boundary": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            },
            "confidence_basis": {
              "type": "object",
              "required": ["kind", "calibration_status", "label", "score_ready", "coverage_fraction", "observed_component_count", "observed_dimension_count", "repeat_measurements_included", "explanation"],
              "properties": {
                "kind": { "const": "inspectable_evidence_basis_v1" },
                "calibration_status": { "const": "not_psychometrically_calibrated" },
                "label": { "type": "string", "minLength": 1 },
                "score_ready": { "type": "boolean" },
                "coverage_fraction": { "type": "number", "minimum": 0, "maximum": 1 },
                "observed_component_count": { "type": "integer", "minimum": 0 },
                "observed_dimension_count": { "type": "integer", "minimum": 0 },
                "repeat_measurements_included": { "type": "boolean" },
                "explanation": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            },
            "claim_boundary": { "type": ["string", "null"] }
          },
          "additionalProperties": true
        },
        "task_performance": {
          "type": "object",
          "properties": {
            "attempted_task_count": { "type": "integer", "minimum": 0 },
            "completed_task_count": { "type": "integer", "minimum": 0 },
            "timed_task_count": { "type": "integer", "minimum": 0 },
            "output_token_task_count": { "type": "integer", "minimum": 0 },
            "timing_coverage_fraction": { "type": "number", "minimum": 0, "maximum": 1 },
            "output_token_coverage_fraction": { "type": "number", "minimum": 0, "maximum": 1 },
            "time_per_task_seconds_median": { "type": ["number", "null"], "minimum": 0 },
            "time_per_task_seconds_p95": { "type": ["number", "null"], "minimum": 0 },
            "output_tokens_per_task_median": { "type": ["number", "null"], "minimum": 0 },
            "output_tokens_per_task_p95": { "type": ["number", "null"], "minimum": 0 },
            "decode_tokens_per_second_median": { "type": ["number", "null"], "minimum": 0 },
            "decode_tokens_per_second_p95": { "type": ["number", "null"], "minimum": 0 },
            "total_elapsed_seconds": { "type": ["number", "null"], "minimum": 0 },
            "total_output_tokens": { "type": ["integer", "null"], "minimum": 0 },
            "measurement_sources": { "type": "array", "items": { "type": "string" } },
            "aggregation_method": { "type": "string" },
            "measurement_status": { "enum": ["measured", "not_reported_by_backend"] }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "deployment": {
      "type": "object",
      "properties": {
        "deployment_profile_id": { "type": "string", "enum": ["interactive_chat_v1", "batch_generation_v1", "long_context_v1"] },
        "deployment_status": { "type": "string" },
        "warmup_runs": { "type": "integer", "minimum": 0 },
        "measured_runs": { "type": "integer", "minimum": 1 },
        "output_tokens_p50": { "type": ["number", "null"], "minimum": 0 },
        "output_tokens_p95": { "type": ["number", "null"], "minimum": 0 },
        "natural_stop_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "token_budget_exhaustion_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "semantic_task_completion_proof": { "type": "boolean" },
        "completion_semantics": { "type": ["string", "null"] },
        "peak_memory_mb": { "type": ["number", "null"], "minimum": 0 },
        "peak_memory_measurement_method": {
          "type": ["string", "null"],
          "enum": [
            "process_rss",
            "nvidia_smi_total_used_delta",
            "container_cgroup_v2_peak",
            "container_cgroup_v1_max_usage",
            "container_cgroup_current_sampled",
            null
          ]
        },
        "model_weights_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "model_buffer_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "kv_cache_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "kv_cache_context_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "memory_fit": {
          "type": "object",
          "required": ["current_context_status", "current_context", "standard_contexts"],
          "properties": {
            "current_context_status": { "type": "string", "enum": ["runtime_reported", "unknown"] },
            "current_context": {
              "oneOf": [
                { "$ref": "#/$defs/memoryFitEstimate" },
                { "type": "null" }
              ]
            },
            "standard_contexts": {
              "type": "object",
              "required": ["2048", "8192", "32768"],
              "properties": {
                "2048": { "$ref": "#/$defs/memoryFitEstimate" },
                "8192": { "$ref": "#/$defs/memoryFitEstimate" },
                "32768": { "$ref": "#/$defs/memoryFitEstimate" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "cost": {
      "type": "object",
      "required": ["cost_source", "benchmark_job_cost_included"],
      "properties": {
        "cost_source": { "type": "string" },
        "benchmark_job_cost_included": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "derived": {
      "type": "object",
      "properties": {
        "passes_verification_floor": { "type": "boolean" },
        "comparison_grade": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "provenance": {
      "type": "object",
      "required": ["source_bundle_origin", "normalized_at", "normalizer_version"],
      "properties": {
        "source_bundle_origin": { "type": "string" },
        "evidence_source": { "type": "string", "enum": ["founder_dogfood", "agent_dogfood", "external_user"] },
        "normalized_at": { "type": "string" },
        "normalizer_version": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "$defs": {
    "memoryComponent": {
      "type": "object",
      "required": ["estimate_bytes", "lower_bound_bytes", "upper_bound_bytes", "source", "residency_group", "memory_domain", "offload_semantics"],
      "properties": {
        "estimate_bytes": { "type": ["integer", "null"], "minimum": 1 },
        "lower_bound_bytes": { "type": ["integer", "null"], "minimum": 1 },
        "upper_bound_bytes": { "type": ["integer", "null"], "minimum": 1 },
        "estimate_range_low_bytes": { "type": ["integer", "null"], "minimum": 1 },
        "estimate_range_high_bytes": { "type": ["integer", "null"], "minimum": 1 },
        "source": { "type": "string", "enum": ["measured", "runtime_reported", "artifact_exact", "formula_estimated", "unknown"] },
        "residency_group": { "type": "string" },
        "memory_domain": { "type": "string" },
        "offload_semantics": { "type": "string" }
      },
      "additionalProperties": false
    },
    "memoryFitEstimate": {
      "type": "object",
      "required": ["estimator_version", "status", "context_tokens", "support_proof", "fit_verdict", "fit_verdict_reason", "components", "required_memory", "residency_semantics"],
      "properties": {
        "estimator_version": { "type": "string", "const": "memory_fit_v1" },
        "status": { "type": "string", "enum": ["estimated", "unknown"] },
        "context_tokens": { "type": "integer", "minimum": 1 },
        "support_proof": { "type": "boolean" },
        "fit_verdict": { "type": "string", "const": "not_evaluated" },
        "fit_verdict_reason": { "type": "string" },
        "components": {
          "type": "object",
          "required": ["model_weights", "model_buffer", "kv_cache", "runtime_overhead", "observed_peak"],
          "properties": {
            "model_weights": { "$ref": "#/$defs/memoryComponent" },
            "model_buffer": { "$ref": "#/$defs/memoryComponent" },
            "kv_cache": { "$ref": "#/$defs/memoryComponent" },
            "runtime_overhead": { "$ref": "#/$defs/memoryComponent" },
            "observed_peak": { "$ref": "#/$defs/memoryComponent" }
          },
          "additionalProperties": false
        },
        "required_memory": {
          "type": "object",
          "required": ["estimate_range_low_bytes", "estimate_range_high_bytes", "lower_bound_bytes", "upper_bound_bytes", "source", "memory_domain"],
          "properties": {
            "estimate_range_low_bytes": { "type": ["integer", "null"], "minimum": 1 },
            "estimate_range_high_bytes": { "type": ["integer", "null"], "minimum": 1 },
            "lower_bound_bytes": { "type": "null" },
            "upper_bound_bytes": { "type": "null" },
            "source": { "type": "string", "enum": ["mixed_estimate", "unknown"] },
            "memory_domain": { "type": "string", "const": "unified_or_combined_memory" }
          },
          "additionalProperties": false
        },
        "residency_semantics": {
          "type": "object",
          "required": ["aggregation", "non_additive_component_groups", "observed_peak_aggregated", "offload_policy", "domain_compatibility_required", "applicable_memory_domains", "device_vram_fit_prohibited", "notes"],
          "properties": {
            "aggregation": { "type": "string", "const": "max_overlapping_model_representations_then_add_context_and_overhead_estimates" },
            "non_additive_component_groups": { "type": "array", "items": { "type": "array", "items": { "type": "string" } } },
            "observed_peak_aggregated": { "type": "boolean", "const": false },
            "offload_policy": { "type": "string", "const": "unknown" },
            "domain_compatibility_required": { "type": "boolean", "const": true },
            "applicable_memory_domains": {
              "type": "array",
              "const": ["unified_memory", "combined_system_memory"]
            },
            "device_vram_fit_prohibited": { "type": "boolean", "const": true },
            "notes": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
