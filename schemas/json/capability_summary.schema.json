{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infergrade.dev/schemas/capability_summary.schema.json",
  "title": "InferGrade Capability Summary Artifact",
  "type": "object",
  "required": [
    "artifact_spec_version",
    "artifact_kind",
    "summary_id",
    "created_at",
    "runner",
    "subject",
    "surfaces",
    "capability_artifacts",
    "unsupported_claim_summary",
    "next_recommended_benchmark_action"
  ],
  "properties": {
    "artifact_spec_version": { "type": "string", "minLength": 1 },
    "artifact_kind": { "const": "capability_summary" },
    "summary_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "runner": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "contract_version": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "subject": {
      "type": "object",
      "properties": {
        "model": { "type": "object", "additionalProperties": true },
        "runtime": { "type": "object", "additionalProperties": true },
        "hardware": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    },
    "surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_summary" }
    },
    "capability_artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact_pointer" }
    },
    "unsupported_claim_summary": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "next_recommended_benchmark_action": {
      "type": "object",
      "required": ["action", "reason"],
      "properties": {
        "action": { "type": "string", "minLength": 1 },
        "surface": {
          "enum": [
            "local_assistant_capability",
            "local_coding_capability",
            "local_reasoning_capability",
            "quant_fidelity",
            "deployment_fitness",
            null
          ]
        },
        "benchmark_check_id": { "type": ["string", "null"] },
        "reason": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "state": {
      "enum": ["scored", "partial", "failed", "skipped", "not_yet_benchmarked", "not_comparable"]
    },
    "lane": {
      "enum": ["smoke", "decision", "reference", "gold"]
    },
    "confidence_label": {
      "enum": [
        "single_smoke",
        "thin_local_sample",
        "repeated_local_sample",
        "sampled_reference",
        "stronger_local_sample",
        "gold",
        "repeated_local_run",
        "reference_sample"
      ]
    },
    "surface_id": {
      "enum": [
        "local_assistant_capability",
        "local_coding_capability",
        "local_reasoning_capability",
        "quant_fidelity",
        "deployment_fitness"
      ]
    },
    "surface_summary": {
      "type": "object",
      "required": [
        "surface",
        "state",
        "score",
        "lane",
        "confidence_label",
        "repetition_count",
        "task_count",
        "failure_count",
        "partial_count",
        "capability_artifacts",
        "unsupported_claims"
      ],
      "properties": {
        "surface": { "$ref": "#/$defs/surface_id" },
        "state": { "$ref": "#/$defs/state" },
        "score": { "type": ["number", "null"] },
        "score_observed": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "score_label": { "type": ["string", "null"] },
        "score_version": { "type": ["string", "null"] },
        "score_method": { "type": ["string", "null"] },
        "score_scale_interpretation": { "type": ["string", "null"] },
        "score_ceiling_display_policy": { "type": ["string", "null"] },
        "score_ceiling": { "type": "object", "additionalProperties": true },
        "score_diagnostic_components": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "score_ready": { "type": "boolean" },
        "score_coverage": { "$ref": "#/$defs/score_coverage" },
        "score_components": { "type": "array", "items": { "$ref": "#/$defs/score_component" } },
        "score_failed_gates": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "score_eligibility": { "anyOf": [{ "$ref": "#/$defs/score_eligibility" }, { "type": "null" }] },
        "score_robustness": { "anyOf": [{ "$ref": "#/$defs/score_robustness" }, { "type": "null" }] },
        "score_confidence_basis": { "anyOf": [{ "$ref": "#/$defs/score_confidence_basis" }, { "type": "null" }] },
        "score_claim_boundary": { "type": ["string", "null"] },
        "lane": { "anyOf": [{ "$ref": "#/$defs/lane" }, { "type": "null" }] },
        "confidence_label": { "anyOf": [{ "$ref": "#/$defs/confidence_label" }, { "type": "null" }] },
        "confidence_explanation": { "type": ["string", "null"] },
        "experimental": { "type": ["boolean", "null"] },
        "repetition_count": { "type": "integer", "minimum": 0 },
        "task_count": { "type": "integer", "minimum": 0 },
        "failure_count": { "type": "integer", "minimum": 0 },
        "partial_count": { "type": "integer", "minimum": 0 },
        "repeatability": { "$ref": "#/$defs/repeatability_summary" },
        "task_performance": { "$ref": "#/$defs/task_performance_summary" },
        "capability_artifacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifact_pointer" }
        },
        "unsupported_claims": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "artifact_pointer": {
      "type": "object",
      "required": ["artifact_kind", "benchmark_id", "surface", "state", "lane", "confidence_label", "path"],
      "properties": {
        "artifact_kind": { "enum": ["capability_run", "benchmark_summary", "unreadable_capability_run"] },
        "benchmark_id": { "type": "string", "minLength": 1 },
        "surface": { "$ref": "#/$defs/surface_id" },
        "state": { "$ref": "#/$defs/state" },
        "lane": { "$ref": "#/$defs/lane" },
        "confidence_label": { "$ref": "#/$defs/confidence_label" },
        "confidence_explanation": { "type": ["string", "null"] },
        "path": { "type": "string", "minLength": 1 },
        "score": { "type": ["number", "null"] },
        "task_count": { "type": "integer", "minimum": 0 },
        "failure_count": { "type": "integer", "minimum": 0 },
        "repeatability": { "$ref": "#/$defs/repeatability_summary" },
        "task_performance": { "$ref": "#/$defs/task_performance_summary" }
      },
      "additionalProperties": true
    },
    "repeatability_summary": {
      "type": "object",
      "properties": {
        "sample_count": { "type": "integer", "minimum": 0 },
        "repetition_count": { "type": "integer", "minimum": 0 },
        "failure_rate": { "type": ["number", "null"], "minimum": 0 },
        "latency_median_ms": { "type": ["number", "null"], "minimum": 0 },
        "latency_p95_ms": { "type": ["number", "null"], "minimum": 0 },
        "latency_variance": { "type": ["number", "null"], "minimum": 0 },
        "ttft_median_ms": { "type": ["number", "null"], "minimum": 0 },
        "ttft_p95_ms": { "type": ["number", "null"], "minimum": 0 },
        "ttft_variance": { "type": ["number", "null"], "minimum": 0 },
        "tokens_per_second_median": { "type": ["number", "null"], "minimum": 0 },
        "tokens_per_second_p95": { "type": ["number", "null"], "minimum": 0 },
        "tokens_per_second_variance": { "type": ["number", "null"], "minimum": 0 },
        "capability_pass_rate_median": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "capability_pass_rate_variance": { "type": ["number", "null"], "minimum": 0 },
        "score_variance": { "type": ["number", "null"], "minimum": 0 },
        "unstable": { "type": "boolean" },
        "instability_reasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "score_coverage": {
      "type": ["object", "null"],
      "properties": {
        "observed_weight": { "type": "number", "minimum": 0 },
        "total_weight": { "type": "number", "minimum": 0 },
        "coverage_fraction": { "type": "number", "minimum": 0, "maximum": 1 },
        "minimum_coverage_fraction": { "type": "number", "minimum": 0, "maximum": 1 },
        "complete": { "type": "boolean" },
        "missing_benchmark_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      },
      "additionalProperties": true
    },
    "score_component": {
      "type": "object",
      "required": ["benchmark_id", "weight", "observed"],
      "properties": {
        "benchmark_id": { "type": "string", "minLength": 1 },
        "display_name": { "type": ["string", "null"] },
        "score_dimension": { "type": ["string", "null"] },
        "score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "weight": { "type": "number", "exclusiveMinimum": 0 },
        "weighted_contribution": { "type": ["number", "null"], "minimum": 0 },
        "observed": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "score_eligibility": {
      "type": "object",
      "required": ["minimum_scored_components", "observed_scored_components", "minimum_score_dimensions", "observed_score_dimensions", "coverage_ready", "diversity_ready", "maximum_component_weight_fraction", "influence_ready"],
      "properties": {
        "minimum_scored_components": { "type": "integer", "minimum": 2 },
        "observed_scored_components": { "type": "integer", "minimum": 0 },
        "minimum_score_dimensions": { "type": "integer", "minimum": 2 },
        "observed_score_dimensions": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "coverage_ready": { "type": "boolean" },
        "diversity_ready": { "type": "boolean" },
        "maximum_component_weight_fraction": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "influence_ready": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "score_robustness": {
      "type": "object",
      "required": ["method", "leave_one_component_out", "max_absolute_delta", "dominant_component_threshold", "dominant_component", "dominant_benchmark_ids", "maximum_observed_weight_fraction", "claim_boundary"],
      "properties": {
        "method": { "const": "leave_one_component_out_v1" },
        "leave_one_component_out": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["omitted_benchmark_id", "score_without_component", "absolute_delta"],
            "properties": {
              "omitted_benchmark_id": { "type": "string", "minLength": 1 },
              "score_without_component": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
              "absolute_delta": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
            },
            "additionalProperties": false
          }
        },
        "max_absolute_delta": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "dominant_component_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "dominant_component": { "type": "boolean" },
        "dominant_benchmark_ids": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "maximum_observed_weight_fraction": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "claim_boundary": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "score_confidence_basis": {
      "type": "object",
      "required": ["kind", "calibration_status", "label", "score_ready", "coverage_fraction", "observed_component_count", "observed_dimension_count", "repeat_measurements_included", "explanation"],
      "properties": {
        "kind": { "const": "inspectable_evidence_basis_v1" },
        "calibration_status": { "const": "not_psychometrically_calibrated" },
        "label": { "enum": ["not_score_ready", "multi_component_dominant", "multi_component_partial_coverage", "multi_component_complete_coverage"] },
        "score_ready": { "type": "boolean" },
        "coverage_fraction": { "type": "number", "minimum": 0, "maximum": 1 },
        "observed_component_count": { "type": "integer", "minimum": 0 },
        "observed_dimension_count": { "type": "integer", "minimum": 0 },
        "repeat_measurements_included": { "type": "boolean" },
        "explanation": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "task_performance_summary": {
      "type": "object",
      "properties": {
        "attempted_task_count": { "type": "integer", "minimum": 0 },
        "completed_task_count": { "type": "integer", "minimum": 0 },
        "timed_task_count": { "type": "integer", "minimum": 0 },
        "output_token_task_count": { "type": "integer", "minimum": 0 },
        "timing_coverage_fraction": { "type": "number", "minimum": 0, "maximum": 1 },
        "output_token_coverage_fraction": { "type": "number", "minimum": 0, "maximum": 1 },
        "time_per_task_seconds_median": { "type": ["number", "null"], "minimum": 0 },
        "time_per_task_seconds_p95": { "type": ["number", "null"], "minimum": 0 },
        "time_to_first_token_ms_median": { "type": ["number", "null"], "minimum": 0 },
        "output_tokens_per_task_median": { "type": ["number", "null"], "minimum": 0 },
        "output_tokens_per_task_p95": { "type": ["number", "null"], "minimum": 0 },
        "decode_tokens_per_second_median": { "type": ["number", "null"], "minimum": 0 },
        "decode_tokens_per_second_p95": { "type": ["number", "null"], "minimum": 0 },
        "total_elapsed_seconds": { "type": ["number", "null"], "minimum": 0 },
        "total_input_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "total_output_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "measurement_sources": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "aggregation_method": { "type": "string", "minLength": 1 },
        "measurement_status": { "enum": ["measured", "not_reported_by_backend"] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
