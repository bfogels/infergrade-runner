{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infergrade.dev/schemas/runtime_receipt.schema.json",
  "title": "InferGrade Compact Runtime Receipt",
  "type": "object",
  "required": [
    "receipt_version",
    "runtime_lock_id",
    "runtime_build_id",
    "runtime_family",
    "runtime_interface",
    "content_scope",
    "origin",
    "provenance_strength",
    "locked_roles",
    "content_manifest_file_count",
    "content_manifest_sha256",
    "role_files",
    "verification"
  ],
  "properties": {
    "receipt_version": { "const": "infergrade_runtime_receipt_v1" },
    "runtime_lock_id": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "runtime_build_id": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "runtime_family": { "type": "string", "minLength": 1, "maxLength": 128 },
    "runtime_interface": { "type": "string", "minLength": 1, "maxLength": 128 },
    "content_scope": { "enum": ["managed_package", "selected_binary_set"] },
    "origin": { "type": "string", "minLength": 1, "maxLength": 64 },
    "maturity": { "type": ["string", "null"], "maxLength": 64 },
    "provenance_strength": {
      "enum": ["independently_signed", "checksum_verified", "local_fingerprint_only"]
    },
    "locked_roles": {
      "type": "array",
      "items": { "enum": ["cli", "server", "perplexity"] },
      "minItems": 2,
      "maxItems": 3,
      "uniqueItems": true
    },
    "content_manifest_file_count": { "type": "integer", "minimum": 1, "maximum": 4096 },
    "content_manifest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "role_files": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["relative_path", "kind", "mode", "size_bytes", "sha256", "roles"],
        "properties": {
          "relative_path": { "type": "string", "minLength": 1, "maxLength": 512 },
          "kind": { "const": "regular" },
          "mode": { "type": "integer", "minimum": 0, "maximum": 511 },
          "size_bytes": { "type": "integer", "minimum": 0, "maximum": 1125899906842624 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "roles": {
            "type": "array",
            "items": { "enum": ["cli", "server", "perplexity"] },
            "minItems": 1,
            "maxItems": 3,
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "verification": {
      "type": "object",
      "required": ["prelaunch", "postrun", "silent_substitution_allowed"],
      "properties": {
        "prelaunch": { "const": "passed" },
        "postrun": { "const": "passed" },
        "silent_substitution_allowed": { "const": false }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
