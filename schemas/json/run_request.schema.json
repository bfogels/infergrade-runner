{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infergrade.dev/schemas/run_request.schema.json",
  "title": "InferGrade Run Request",
  "type": "object",
  "required": ["spec_version", "run"],
  "properties": {
    "spec_version": {
      "type": "string"
    },
    "run": {
      "type": "object",
      "required": ["model", "backend", "tier"],
      "properties": {
        "model": { "type": "string", "minLength": 1 },
        "backend": { "type": "string", "enum": ["llama.cpp", "vllm"] },
        "tier": { "type": "string", "enum": ["canary", "standard", "gold"] },
        "capability_suite_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "benchmark_group_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "benchmark_check_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "benchmark_shortcut_id": { "type": "string" },
        "quant_artifact": { "type": "string" },
        "use_case": { "type": "string", "enum": ["agentic_coding", "general_assistant", "reasoning"] },
        "deployment_profiles": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["interactive_chat_v1", "batch_generation_v1", "long_context_v1"]
          },
          "uniqueItems": true
        },
        "execution_mode": {
          "type": "string",
          "enum": ["local_container", "local_native", "cloud_container", "manual_external"]
        },
        "output_dir": { "type": "string" },
        "upload": { "type": "boolean" },
        "capability": { "type": "string", "enum": ["auto", "none"] }
      },
      "additionalProperties": false
    },
    "overrides": {
      "type": "object",
      "properties": {
        "backend_flags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "generation_preset": { "type": "string" },
        "chat_template_id": { "type": "string" },
        "tokenizer_id": { "type": "string" },
        "warmup_runs": { "type": "integer", "minimum": 0 },
        "measured_runs": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "cost": {
      "type": "object",
      "properties": {
        "source": { "type": "string", "enum": ["observed", "billing_import", "user_provided", "estimated", "none"] },
        "hourly_rate_usd": { "type": "number", "minimum": 0 },
        "job_cost_usd": { "type": "number", "minimum": 0 },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "quantized_weights": {
          "type": "object",
          "required": ["uri"],
          "properties": {
            "uri": { "type": "string" },
            "sha256": { "type": "string" },
            "filename": { "type": "string" },
            "revision": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "properties": {
        "backend_image": { "type": "string" },
        "artifact_cache_dir": { "type": "string" },
        "runtime_selector": { "$ref": "runtime_selector.schema.json" }
      },
      "additionalProperties": false
    },
    "ontology_hints": {
      "type": "object",
      "properties": {
        "family_id": { "type": "string" },
        "family_name": { "type": "string" },
        "publisher": { "type": "string" },
        "primary_modality": { "type": "string", "enum": ["text", "multimodal", "unknown"] },
        "parameter_scale": { "type": "string" },
        "checkpoint_id": { "type": "string" },
        "checkpoint_name": { "type": "string" },
        "upstream_revision": { "type": "string" },
        "training_stage": {
          "type": "string",
          "enum": ["base", "instruction_tuned", "reasoning_tuned", "domain_tuned", "unknown"]
        },
        "quantization_format": { "type": "string" },
        "quantization_label": { "type": "string" },
        "quantization_family": { "type": "string" },
        "quantization_scheme": { "type": "string" },
        "weight_precision_bits": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "properties": {
        "submitter": { "type": "string" },
        "evidence_source": {
          "type": "string",
          "enum": ["founder_dogfood", "agent_dogfood", "external_user"]
        },
        "notes": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
